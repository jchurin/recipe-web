      { "id": "2", "name": "pancetta", "quantity": 200, "unit": "g", "notes": "diced" },
      { "id": "3", "name": "eggs", "quantity": 4, "unit": "large" },
      { "id": "4", "name": "Pecorino Romano cheese", "quantity": 100, "unit": "g", "notes": "grated" },
      { "id": "5", "name": "black pepper", "quantity": 2, "unit": "tsp", "notes": "freshly ground" },
