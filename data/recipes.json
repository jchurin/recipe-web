    "id": "pasta-carbonara",
    "title": "Classic Pasta Carbonara",
    "description": "A traditional Italian pasta dish made with eggs, cheese, pancetta, and black pepper. Creamy and satisfying without using cream.",
    "images": ["/images/recipes/carbonara-1.jpg", "/images/recipes/carbonara-2.jpg"],
    "prepTime": 10,
    "cookTime": 20,
    "totalTime": 30,
    "servings": 4,
    "difficulty": "medium",
